# ============================================================
# Required — Admin Authentication
# ============================================================
ADMIN_PASSWORD=

# ============================================================
# Required — GPS Tracking
# ============================================================
NEXT_PUBLIC_RTIRL_PULL_KEY=

# ============================================================
# Required — Location & Weather Services
# ============================================================
NEXT_PUBLIC_LOCATIONIQ_KEY=
NEXT_PUBLIC_OPENWEATHERMAP_KEY=

# ============================================================
# Required — Upstash Redis (KV store for ephemeral/cache state)
# Get from: https://console.upstash.com
# ============================================================
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ============================================================
# Required — Supabase (persistent database)
# Get from: Supabase Dashboard → Project Settings → API
# ============================================================
SUPABASE_URL=                                    # e.g. https://xyzxyz.supabase.co
SUPABASE_SECRET_DEFAULT_KEY=                     # Secret key (sb_secret_...) — server-only, never expose to browser
NEXT_PUBLIC_SUPABASE_URL=                        # same as SUPABASE_URL — safe for client use
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=    # Publishable key (sb_publishable_...) — safe for client, restricted by RLS

# ============================================================
# Kick Bot Integration
# ============================================================
APP_URL=                             # Primary public URL of the app e.g. https://tazo.wtf
KICK_CLIENT_ID=                      # From Kick Dev dashboard
KICK_CLIENT_SECRET=                  # From Kick Dev dashboard
# KICK_MESSAGE_DEBUG_PREFIX=         # Optional: e.g. "[bot] " prefix to identify bot messages

# ============================================================
# Optional — Additional Features
# ============================================================
NEXT_PUBLIC_PULSOID_TOKEN=           # Heart rate monitoring via Pulsoid
WELLNESS_IMPORT_SECRET=              # Auth secret for Health Auto Export POST /api/wellness/import
NEXT_PUBLIC_MAPTILER_KEY=            # Map tiles (falls back to OpenFreeMap if not set)
EXCHANGERATE_API_KEY=                # Exchange rates (free tier at https://www.exchangerate-api.com)
WISE_API_TOKEN=                      # Wise card integration for automatic wallet deductions

# ============================================================
# Discord OAuth — Viewer Dashboard
# Get from: https://discord.com/developers/applications → New Application → OAuth2
# ============================================================
DISCORD_CLIENT_ID=                   # Application ID from Discord Developer Portal
DISCORD_CLIENT_SECRET=               # Client secret from Discord Developer Portal
VIEWER_SESSION_SECRET=               # Random secret for signing viewer session tokens (e.g. a long random string)

# ============================================================
# Discord Bot — Subscriber Role Sync (optional)
# Automatically assigns/removes a Discord role when viewers sub on Kick.
# Setup: discord.com/developers → New Application → Bot → Copy Token
#        Invite bot to your server with "Manage Roles" permission
#        Right-click server → Copy Server ID  →  DISCORD_GUILD_ID
#        Right-click role → Copy Role ID  →  DISCORD_SUBSCRIBER_ROLE_ID
#        Bot's highest role must be above the subscriber role in the hierarchy
# ============================================================
DISCORD_BOT_TOKEN=                   # Bot token (starts with MT... or similar) — server-only, never expose
DISCORD_GUILD_ID=                    # Your Discord server/guild ID
DISCORD_SUBSCRIBER_ROLE_ID=          # ID of the role to assign to Kick subscribers

# ============================================================
# Vercel / Deployment
# ============================================================
CRON_SECRET=                         # Vercel cron auth secret — set in Vercel dashboard under Cron settings
NEXT_PUBLIC_BUILD_VERSION=           # Set automatically by Vercel — used for OBS cache-busting
# KICK_WEBHOOK_LOGGING=true          # Set to "true" to log recent webhook events to KV (debugging)